# LinaresYa - variables de entorno
# Copia este archivo como .env.local y rellena con tus valores reales.
# .env.local NO se sube al repo (ya esta en .gitignore).

# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key - SOLO en el servidor. Se usa para que /publicar pueda insertar
# negocios pendientes de aprobacion saltando RLS. NO usar prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Password del panel administrador (/admin). Usa una clave larga y unica.
# SOLO servidor, no usar prefijo NEXT_PUBLIC_.
ADMIN_PASSWORD=pon-aqui-una-clave-larga-y-unica

# URL canonica del sitio (sin slash al final). Usada en sitemap, robots y OG.
NEXT_PUBLIC_SITE_URL=https://linaresya.vercel.app

# Cloudflare Turnstile (captcha para /publicar). Gratis en
# https://dash.cloudflare.com/?to=/:account/turnstile
# Dejar vacias desactiva el captcha (util para dev local).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADBgXSsoV5cFnhqa
TURNSTILE_SECRET_KEY=0x4AAAAAADBgXbHXG6gtj-U8eD81mRs8J3k

# Resend (emails transaccionales). Gratis: 3000/mes, 100/dia.
# Crea una API key en https://resend.com/api-keys
# Si no estan seteadas, simplemente no se envian emails (util para dev).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Email al que le avisamos cuando alguien publica un negocio pendiente.
ADMIN_EMAIL=willsonnuevo1@gmail.com
# (Opcional) Remitente por defecto. Si omites esto se usa onboarding@resend.dev
# que funciona sin verificar dominio. Cuando verifiques linaresya.cl podes usar
# "LinaresYa <avisos@linaresya.cl>".
# RESEND_FROM=LinaresYa <avisos@linaresya.cl>
